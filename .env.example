# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your key at https://aistudio.google.com/apikey
# This key is used ONLY by the server (server.js) — never exposed to the browser.
GEMINI_API_KEY="your_api_key_here"

# PORT: Port for the Express API server (default: 3001 in dev, 8080 in Docker/Cloud Run)
PORT=3001

# NODE_ENV: Set to "production" in deployment (auto-set in Dockerfile & Cloud Run)
# NODE_ENV=production

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins (optional in production)
# In Cloud Run, same-origin requests are allowed by default.
# ALLOWED_ORIGINS=https://your-app.run.app
